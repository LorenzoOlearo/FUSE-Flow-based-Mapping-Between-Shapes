{
    "dataset": {
        "name": "faust",
        "type": "range",
        "range_start": 80,
        "range_end": 100,
        "file_format": "tr_reg_{:03d}",
        "file_extension": ".off",
        "data_path": "../data/faust/test_set/",
        "landmarks": [412, 5891, 6593, 3323, 2119]
    },
    "output": {
        "base_dir": "../experiments/faust/faust_5_landmarks/"
    },
    "training": {
        "blr": 5e-7,
        "epochs": 10000,
        "method": "FM",
        "network": "MLP",
        "batch_size": 10000,
        "num_points_train": 10000,
        "learning_rate": 0.01,
        "distribution": "Gaussian",
        "embedding_dim": 5,
        "embedding": "features_only",
        "features_type": "landmarks",
        "device": "cuda:1"
    },
    "execution": {
        "skip_existing": true,
        "checkpoint_name": "checkpoint-9999.pth"
    }
}